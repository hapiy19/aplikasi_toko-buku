<?xml version="1.0" encoding="UTF-8"?>
<project name="TokoBuku-impl" basedir=".." xmlns:j2seproject3="http://www.netbeans.org/ns/j2se-project/3">
    <fail message="Please build using Ant 1.8.0 or higher.">
        <condition><not><antversion atleast="1.8.0"/></not></condition>
    </fail>
    <property file="nbproject/private/private.properties"/>
    <property file="nbproject/project.properties"/>
    <target name="-init">
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>
    <target name="-init-macrodef-javac">
        <macrodef name="javac" uri="http://www.netbeans.org/ns/j2se-project/3">
            <attribute default="${src.dir}" name="srcdir"/>
            <attribute default="${build.classes.dir}" name="destdir"/>
            <attribute default="${javac.classpath}" name="classpath"/>
            <element name="customize" optional="true"/>
            <sequential>
                <javac debug="true" deprecation="${javac.deprecation}" destdir="@{destdir}"
                       encoding="${source.encoding}" excludes="${excludes}"
                       includeantruntime="false" includes="${includes}"
                       source="${javac.source}" target="${javac.target}" srcdir="@{srcdir}">
                    <classpath><path path="@{classpath}"/></classpath>
                    <customize/>
                </javac>
            </sequential>
        </macrodef>
    </target>
    <target depends="-init,-init-macrodef-javac" name="compile">
        <j2seproject3:javac/>
    </target>
    <target depends="-init" name="-pre-pre-jar">
        <mkdir dir="${build.classes.dir}"/>
    </target>
    <target depends="compile,-pre-pre-jar" name="jar">
        <mkdir dir="${dist.dir}"/>
        <jar compress="${jar.compress}" destfile="${dist.jar}" manifest="${manifest.file}">
            <fileset dir="${build.classes.dir}"/>
        </jar>
        <copy todir="${dist.dir}/lib">
            <fileset dir="lib" includes="*.jar"/>
        </copy>
    </target>
    <target depends="jar" name="run">
        <java classname="${main.class}" classpath="${run.classpath}" fork="true"/>
    </target>
    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>
</project>
